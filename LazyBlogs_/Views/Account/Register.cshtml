@model LazyBlogs_.ViewModels.Account.RegisterViewModel

@{
    ViewData["Title"] = "Join LazyBlogging_ — Free Forever";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/landing.css" />
    <link rel="stylesheet" href="~/css/auth.css" />
</head>
<body>
    <div class="auth-container">
        <div class="auth-card">
            <!-- Logo -->
            <div class="auth-header">
                <a href="/" class="auth-logo">Lazy<span>Blogging</span><em>_</em></a>
                <p class="auth-subtitle">Start your writing journey today</p>
            </div>

            <!-- Register Form -->
            <form asp-action="Register" method="post" class="auth-form">
                <div asp-validation-summary="ModelOnly" class="text-danger auth-error-summary"></div>

                <div class="auth-form-group">
                    <label asp-for="FullName" class="auth-label">
                        <i class="fa-solid fa-user"></i> Full Name
                    </label>
                    <input asp-for="FullName" class="auth-input" placeholder="Enter your full name" />
                    <span asp-validation-for="FullName" class="text-danger auth-error"></span>
                </div>

                <div class="auth-form-group">
                    <label asp-for="Email" class="auth-label">
                        <i class="fa-solid fa-envelope"></i> Email Address
                    </label>
                    <input asp-for="Email" class="auth-input" placeholder="you@example.com" />
                    <span asp-validation-for="Email" class="text-danger auth-error"></span>
                </div>

                <div class="auth-form-group">
                    <label asp-for="Password" class="auth-label">
                        <i class="fa-solid fa-lock"></i> Password
                    </label>
                    <div class="auth-password-wrapper">
                        <input asp-for="Password" class="auth-input" placeholder="Create a strong password" />
                        <button type="button" class="auth-password-toggle" onclick="togglePasswordVisibility(this)">
                            <i class="fa-solid fa-eye"></i>
                        </button>
                    </div>
                    <span asp-validation-for="Password" class="text-danger auth-error"></span>
                    <div class="auth-password-hint">
                        <i class="fa-solid fa-info-circle"></i> Minimum 6 characters
                    </div>
                </div>

                <div class="auth-form-group">
                    <label asp-for="ConfirmPassword" class="auth-label">
                        <i class="fa-solid fa-check-circle"></i> Confirm Password
                    </label>
                    <div class="auth-password-wrapper">
                        <input asp-for="ConfirmPassword" class="auth-input" placeholder="Confirm your password" />
                        <button type="button" class="auth-password-toggle" onclick="togglePasswordVisibility(this)">
                            <i class="fa-solid fa-eye"></i>
                        </button>
                    </div>
                    <span asp-validation-for="ConfirmPassword" class="text-danger auth-error"></span>
                </div>

                <button type="submit" class="auth-btn auth-btn-primary">
                    <i class="fa-solid fa-user-plus"></i> Create Free Account
                </button>

                <div class="auth-divider">
                    <span>Already have an account?</span>
                </div>

                <a href="/Account/Login" class="auth-btn auth-btn-outline">
                    <i class="fa-solid fa-sign-in-alt"></i> Sign In Instead
                </a>
            </form>

            <!-- Footer -->
            <div class="auth-footer">
                <p class="auth-footer-text">
                    By joining, you agree to our
                    <a href="/Home/Privacy">Privacy Policy</a> and
                    <a href="/Home/Terms">Terms of Service</a>
                </p>
                <p class="auth-footer-features">
                    <i class="fa-solid fa-check-circle"></i> Free forever
                    <span class="auth-dot">·</span>
                    <i class="fa-solid fa-check-circle"></i> No credit card
                    <span class="auth-dot">·</span>
                    <i class="fa-solid fa-check-circle"></i> Start reading instantly
                </p>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/auth.js" asp-append-version="true"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>

    @* @await RenderSectionAsync("Scripts", required: false) *@
</body>
</html>