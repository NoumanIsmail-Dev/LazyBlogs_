@{
    ViewData["Title"] = "LazyBlogging_ — Read. Write. Vibe.";
}
    <!-- ═══════════════════════════════════════════
         HERO
    ═══════════════════════════════════════════ -->
    <section class="lb-hero" id="hero">
        <div class="lb-hero__noise"></div>

        <div class="lb-hero__body container">
            <div class="lb-hero__eyebrow">Free forever &nbsp;·&nbsp; No credit card &nbsp;·&nbsp; No plans</div>
            <h1 class="lb-hero__headline">
                Where good writing<br />
                <span class="lb-hero__accent">finds its people.</span>
            </h1>
            <p class="lb-hero__sub">
                Read blogs that actually matter. Follow writers you love.
                Publish your own stories when you're ready — no gatekeeping, no fee.
            </p>
            <div class="lb-hero__cta">
                <a href="/Account/Register" class="lb-btn lb-btn--primary lb-btn--lg">Start reading free</a>
                <a href="#how" class="lb-btn lb-btn--outline lb-btn--lg">See how it works</a>
            </div>

            <div class="lb-hero__stats">
                <div class="lb-stat">
                    <span class="lb-stat__num">100%</span>
                    <span class="lb-stat__label">Free, always</span>
                </div>
                <div class="lb-stat__divider"></div>
                <div class="lb-stat">
                    <span class="lb-stat__num">3 roles</span>
                    <span class="lb-stat__label">Reader · Editor · Admin</span>
                </div>
                <div class="lb-stat__divider"></div>
                <div class="lb-stat">
                    <span class="lb-stat__num">Open</span>
                    <span class="lb-stat__label">Anyone can join</span>
                </div>
            </div>
        </div>

        <div class="lb-hero__scroll-hint">
            <span>Scroll to explore</span>
            <i class="fa-solid fa-chevron-down lb-bounce"></i>
        </div>
    </section>

    <!-- ═══════════════════════════════════════════
